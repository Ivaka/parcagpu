# Multi-stage build for the parcagpu test container.
# Builds the .so and mock CUPTI/CUDA libraries inside Docker (no local build needed),
# then packages them into a slim runtime image for K8s demo workloads.
#
# The resulting image contains:
#   /test/build/lib/libparcagpucupti.so  — the profiling library
#   /test/build/lib/libcuda.so           — mock CUDA driver
#   /test/build/lib/libcuda.so.1         — symlink
#   /test/build/lib/libcupti.so          — mock CUPTI
#   /test/build/lib/libcupti.so.12       — symlink
#   /test/build/bin/test_cupti_prof      — mock test harness
#   /test/pc_sample_toy.cubin            — mock cubin for PC sampling

ARG CUDA_HEADERS=ghcr.io/parca-dev/cuda-headers:12
FROM ${CUDA_HEADERS} AS cuda-headers

FROM ubuntu:24.04 AS builder

RUN apt-get update && apt-get install -y \
    cmake \
    make \
    g++ \
    systemtap-sdt-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY --from=cuda-headers /usr/local/cuda /usr/local/cuda
COPY src /build/src
COPY proton /build/proton
COPY CMakeLists.txt /build/
COPY test/ /build/test/

# Build the .so and mock test infrastructure (mock CUPTI/CUDA + test binary)
RUN mkdir -p build && \
    cd build && \
    cmake -DCUDA_INCLUDE_DIR=/usr/local/cuda/include -DBUILD_TESTS=ON .. && \
    make -j$(nproc)

# Runtime stage
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /test

RUN mkdir -p build/bin build/lib

# Copy the built library
COPY --from=builder /build/build/lib/libparcagpucupti.so ./build/lib/

# Copy the test binary and mock libraries
COPY --from=builder /build/build/bin/test_cupti_prof ./build/bin/
COPY --from=builder /build/build/lib/libcuda.so ./build/lib/
COPY --from=builder /build/build/lib/libcuda.so.1 ./build/lib/
COPY --from=builder /build/build/lib/libcupti.so ./build/lib/
COPY --from=builder /build/build/lib/libcupti.so.12 ./build/lib/

# Copy the mock cubin for PC sampling tests
COPY --from=builder /build/test/pc_sample_toy.cubin ./pc_sample_toy.cubin

ENV LD_LIBRARY_PATH=/test/build/lib
ENV PARCAGPU_DEBUG=1

ENTRYPOINT ["/test/build/bin/test_cupti_prof", "/test/build/lib/libparcagpucupti.so"]
CMD []
